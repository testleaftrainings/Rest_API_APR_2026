          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Status code name has Created\", function () {",
              "    pm.response.to.have.status(\"Created\");",
              "});",
              "",
              "pm.test(\"Response format should be in JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.contains(\"json\");",
              "});",
              "",
              "pm.test(\"Validate the value of the short_description key\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.result.short_description).to.eql(pm.iterationData.get(\"ShortDescription\"));",
              "});",
              "",
              "pm.test(\"Validate the value of the description key\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.result.description).to.eql(pm.iterationData.get(\"Description\"));",
              "});",
              "",
              "pm.test(\"Validate the value of the category key\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.result.category).to.eql(pm.iterationData.get(\"Category\"));",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
